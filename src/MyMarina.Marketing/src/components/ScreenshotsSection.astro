---
// Screenshots are captured via the playwright-cli skill whenever a new UI feature ships.
// Run: /playwright-cli capture — and commit updated images to public/screenshots/.
const screenshots = [
  {
    src: '/screenshots/operator-dashboard.png',
    alt: 'MyMarina operator dashboard showing marina overview, slip occupancy, and quick stats',
    caption: 'Operator Dashboard',
  },
  {
    src: '/screenshots/slip-map.png',
    alt: 'Interactive slip map with colour-coded availability — available, occupied, reserved, and under maintenance',
    caption: 'Slip Map',
  },
  {
    src: '/screenshots/customer-portal.png',
    alt: "Customer self-service portal showing slip details, boats, and upcoming bookings",
    caption: 'Customer Portal',
  },
  {
    src: '/screenshots/invoicing.png',
    alt: 'Invoicing screen with line items, payment status, and bulk actions',
    caption: 'Invoicing',
  },
];
---

<section id="screenshots" class="py-20 px-4 sm:px-6 bg-secondary/10">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-14">
      <h2 class="text-3xl font-bold mb-3">See it in action</h2>
      <p class="text-muted-foreground text-lg max-w-xl mx-auto">
        A clean, modern UI designed for daily use by marina operators and their customers.
      </p>
    </div>

    <!-- Walkthrough video / GIF — replace src with a real asset when available -->
    <div class="mb-10 rounded-xl overflow-hidden border border-border shadow-sm bg-secondary/20 aspect-video flex items-center justify-center">
      <!-- TODO: replace with <video> or <img> once walkthrough asset is recorded -->
      <div class="text-center text-muted-foreground px-8">
        <div class="text-4xl mb-3" aria-hidden="true">▶</div>
        <p class="font-medium">Product walkthrough coming soon</p>
        <p class="text-sm mt-1">Try the live demo above to experience MyMarina now.</p>
      </div>
    </div>

    <div class="grid sm:grid-cols-2 gap-6">
      {screenshots.map(shot => (
        <figure class="rounded-xl overflow-hidden border border-border shadow-sm bg-secondary/20">
          {/* Screenshot images are generated by playwright-cli and committed to public/screenshots/. */}
          {/* Replace the placeholder below with <Image src={import(shot.src)} alt={shot.alt} /> once images exist. */}
          <div class="aspect-video bg-gradient-to-br from-slate-100 to-slate-200 flex items-center justify-center text-muted-foreground text-sm">
            <span aria-hidden="true">📸</span>&nbsp;{shot.caption} screenshot coming soon
          </div>
          <figcaption class="px-4 py-3 text-sm font-medium text-center">{shot.caption}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
